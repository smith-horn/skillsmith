{
  "name": "@skillsmith/core",
  "version": "0.5.8",
  "description": "Core types and utilities for Skillsmith",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./errors": {
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js",
      "default": "./dist/src/errors.js"
    },
    "./embeddings": {
      "types": "./dist/src/embeddings/index.d.ts",
      "import": "./dist/src/embeddings/index.js",
      "default": "./dist/src/embeddings/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js",
      "default": "./dist/src/testing/index.js"
    },
    "./learning": {
      "types": "./dist/src/learning/index.d.ts",
      "import": "./dist/src/learning/index.js",
      "default": "./dist/src/learning/index.js"
    },
    "./billing": {
      "types": "./dist/src/billing/index.d.ts",
      "import": "./dist/src/billing/index.js",
      "default": "./dist/src/billing/index.js"
    },
    "./testkit": {
      "types": "./dist/tests/testkit.d.ts",
      "import": "./dist/tests/testkit.js",
      "default": "./dist/tests/testkit.js"
    },
    "./services/skill-installation-helpers": {
      "types": "./dist/src/services/skill-installation.helpers.d.ts",
      "import": "./dist/src/services/skill-installation.helpers.js",
      "default": "./dist/src/services/skill-installation.helpers.js"
    }
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/lib/forbid-local-publish.mjs && npm run build && npm run test",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:security": "vitest run tests/security",
    "benchmark": "npx tsx src/benchmarks/cli.ts",
    "benchmark:search": "npx tsx src/benchmarks/cli.ts --suite search",
    "benchmark:index": "npx tsx src/benchmarks/cli.ts --suite index",
    "benchmark:cache": "npx tsx src/benchmarks/cli.ts --suite cache",
    "benchmark:embedding": "npx tsx src/benchmarks/cli.ts --suite embedding",
    "benchmark:incremental-parse": "npx tsx src/benchmarks/incrementalParseBenchmark.ts",
    "import:skills": "npx tsx src/scripts/import-to-database.ts"
  },
  "dependencies": {
    "@huggingface/transformers": "3.8.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/instrumentation-http": "0.214.0",
    "@opentelemetry/instrumentation-runtime-node": "0.27.0",
    "@opentelemetry/instrumentation-undici": "0.24.0",
    "@opentelemetry/resources": "2.6.1",
    "@opentelemetry/sdk-node": "0.214.0",
    "@opentelemetry/sdk-trace-base": "2.7.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "fts5-sql-bundle": "1.0.2",
    "lru-cache": "11.3.3",
    "posthog-node": "5.29.2",
    "stripe": "20.3.0",
    "tree-sitter-wasms": "0.1.13",
    "typescript": "5.9.3",
    "web-tree-sitter": "0.26.8",
    "zod": "4.2.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "11.10.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "vitest": "4.1.2"
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "license": "Elastic-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/smith-horn/skillsmith.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/smith-horn/skillsmith#readme",
  "bugs": {
    "url": "https://github.com/smith-horn/skillsmith/issues"
  },
  "keywords": [
    "ai",
    "skills",
    "mcp",
    "llm"
  ],
  "engines": {
    "node": ">=22.22.0"
  }
}
