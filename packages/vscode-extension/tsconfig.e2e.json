{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "@wdio/globals/types", "@wdio/mocha-framework", "wdio-vscode-service"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true
  },
  "include": ["e2e/**/*.ts"]
}
