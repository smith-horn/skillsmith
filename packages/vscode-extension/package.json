{
  "name": "skillsmith-vscode",
  "displayName": "Skillsmith",
  "description": "Discover and install agent skills directly in VS Code",
  "version": "0.7.0",
  "publisher": "skillsmith",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "skills",
    "agent-skills",
    "ai",
    "mcp",
    "claude",
    "cursor",
    "copilot",
    "developer-tools",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "license": "Elastic-2.0",
  "icon": "resources/skillsmith-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/smith-horn/skillsmith"
  },
  "homepage": "https://skillsmith.app",
  "bugs": {
    "url": "https://github.com/smith-horn/skillsmith/issues"
  },
  "galleryBanner": {
    "color": "#0d0d0f",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skillsmith.searchSkills",
        "title": "Search Skills",
        "category": "Skillsmith",
        "icon": "$(search)"
      },
      {
        "command": "skillsmith.installSkill",
        "title": "Install Skill",
        "category": "Skillsmith",
        "icon": "$(cloud-download)"
      },
      {
        "command": "skillsmith.refreshSkills",
        "title": "Refresh Skills",
        "category": "Skillsmith",
        "icon": "$(refresh)"
      },
      {
        "command": "skillsmith.filterSkills",
        "title": "Filter Skills",
        "category": "Skillsmith",
        "icon": "$(filter)"
      },
      {
        "command": "skillsmith.clearSkillFilters",
        "title": "Clear Skill Filters",
        "category": "Skillsmith",
        "icon": "$(clear-all)"
      },
      {
        "command": "skillsmith.viewSkillDetails",
        "title": "View Skill Details",
        "category": "Skillsmith"
      },
      {
        "command": "skillsmith.mcpReconnect",
        "title": "Connect/Reconnect to MCP Server",
        "category": "Skillsmith",
        "icon": "$(plug)"
      },
      {
        "command": "skillsmith.createSkill",
        "title": "Create Skill",
        "category": "Skillsmith",
        "icon": "$(add)"
      },
      {
        "command": "skillsmith.uninstallSkill",
        "title": "Uninstall Skill",
        "category": "Skillsmith",
        "icon": "$(trash)"
      },
      {
        "command": "skillsmith.recommendSkills",
        "title": "Recommend Skills",
        "category": "Skillsmith",
        "icon": "$(lightbulb)"
      },
      {
        "command": "skillsmith.compareSkills",
        "title": "Compare Skills",
        "category": "Skillsmith",
        "icon": "$(diff)"
      },
      {
        "command": "skillsmith.diffSkill",
        "title": "Check Skill for Updates (Individual+)",
        "category": "Skillsmith",
        "icon": "$(versions)"
      },
      {
        "command": "skillsmith.selectForCompare",
        "title": "Select for Compare",
        "category": "Skillsmith",
        "icon": "$(compare-changes)"
      },
      {
        "command": "skillsmith.compareWithSelected",
        "title": "Compare with Selected",
        "category": "Skillsmith",
        "icon": "$(diff)"
      },
      {
        "command": "skillsmith.auditInventory",
        "title": "Audit Skill Inventory",
        "category": "Skillsmith",
        "icon": "$(search)"
      },
      {
        "command": "skillsmith.runValidate",
        "title": "Validate Skill",
        "category": "Skillsmith",
        "icon": "$(check)"
      },
      {
        "command": "skillsmith.dismissNextSteps",
        "title": "Dismiss",
        "category": "Skillsmith",
        "icon": "$(close)"
      }
    ],
    "keybindings": [
      {
        "command": "skillsmith.searchSkills",
        "key": "ctrl+k ctrl+y",
        "mac": "cmd+k cmd+y"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillsmith",
          "title": "Skillsmith",
          "icon": "resources/skillsmith.svg"
        }
      ]
    },
    "views": {
      "skillsmith": [
        {
          "id": "skillsmith.skillsView",
          "name": "Skills",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "skillsmith.skillsView",
        "contents": "No skills installed yet.\n[Search Skills](command:skillsmith.searchSkills)\n[Create a Skill](command:skillsmith.createSkill)"
      }
    ],
    "walkthroughs": [
      {
        "id": "skillsmith.getStarted",
        "title": "Get Started with Skillsmith",
        "description": "Discover, install, and author agent skills without leaving VS Code.",
        "steps": [
          {
            "id": "skillsmith.walkthrough.discover",
            "title": "Discover skills",
            "description": "Search the Skillsmith registry by keyword.\n[Search Skills](command:skillsmith.searchSkills)",
            "media": {
              "markdown": "resources/walkthrough/discover.md"
            }
          },
          {
            "id": "skillsmith.walkthrough.install",
            "title": "Install a skill",
            "description": "Install any skill with one click from the Available Skills group in the Skills view.\n[Open Skillsmith Sidebar](command:workbench.view.extension.skillsmith)",
            "media": {
              "markdown": "resources/walkthrough/install.md"
            }
          },
          {
            "id": "skillsmith.walkthrough.author",
            "title": "Create your own skill",
            "description": "Scaffold a new skill via the Skillsmith CLI — author, name, description, type.\n[Create Skill](command:skillsmith.createSkill)",
            "media": {
              "markdown": "resources/walkthrough/create.md"
            }
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "skillsmith.searchSkills",
          "when": "view == skillsmith.skillsView",
          "group": "navigation"
        },
        {
          "command": "skillsmith.filterSkills",
          "when": "view == skillsmith.skillsView",
          "group": "navigation"
        },
        {
          "command": "skillsmith.clearSkillFilters",
          "when": "view == skillsmith.skillsView && skillsmith.hasActiveFilters",
          "group": "navigation"
        },
        {
          "command": "skillsmith.refreshSkills",
          "when": "view == skillsmith.skillsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skillsmith.dismissNextSteps",
          "when": "view == skillsmith.skillsView && viewItem == nextStepsGroup",
          "group": "inline"
        },
        {
          "command": "skillsmith.installSkill",
          "when": "view == skillsmith.skillsView && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "skillsmith.viewSkillDetails",
          "when": "viewItem == skill"
        },
        {
          "command": "skillsmith.viewSkillDetails",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill",
          "group": "navigation"
        },
        {
          "command": "skillsmith.uninstallSkill",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill",
          "group": "inline"
        },
        {
          "command": "skillsmith.uninstallSkill",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill"
        },
        {
          "command": "skillsmith.selectForCompare",
          "when": "view == skillsmith.skillsView && viewItem =~ /^(skill|installedSkill)$/",
          "group": "skillsmith_compare@1"
        },
        {
          "command": "skillsmith.compareWithSelected",
          "when": "view == skillsmith.skillsView && viewItem =~ /^(skill|installedSkill)$/ && skillsmith.compareSourceSet",
          "group": "skillsmith_compare@2"
        },
        {
          "command": "skillsmith.diffSkill",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill",
          "group": "skillsmith_diff@1"
        }
      ],
      "commandPalette": [
        {
          "command": "skillsmith.selectForCompare",
          "when": "false"
        },
        {
          "command": "skillsmith.compareWithSelected",
          "when": "false"
        },
        {
          "command": "skillsmith.dismissNextSteps",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "Skillsmith",
      "properties": {
        "skillsmith.skillsDirectory": {
          "type": "string",
          "default": "~/.claude/skills",
          "description": "Directory where skills are installed"
        },
        "skillsmith.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom API endpoint for skill search (leave empty for default)"
        },
        "skillsmith.mcp.serverCommand": {
          "type": "string",
          "default": "npx",
          "description": "Command to run the MCP server. Defaults to `npx`, which is auto-resolved against your login-shell PATH and common Node version-manager directories (nvm, fnm, volta, asdf, Homebrew). Set an absolute path only if auto-resolution fails."
        },
        "skillsmith.mcp.serverArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "@skillsmith/mcp-server"
          ],
          "description": "Arguments for the MCP server command. Paired with the resolved server command."
        },
        "skillsmith.mcp.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to MCP server on extension activation"
        },
        "skillsmith.mcp.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reconnect when connection is lost"
        },
        "skillsmith.mcp.connectionTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Connection timeout in milliseconds"
        },
        "skillsmith.mcp.minServerVersion": {
          "type": "string",
          "default": "0.4.9",
          "description": "Minimum required @skillsmith/mcp-server version. When the connected server is older, an informational toast prompts to run `npm install -g @skillsmith/mcp-server@latest`. Non-blocking."
        },
        "skillsmith.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Send anonymous usage telemetry. Also respects VS Code's global `telemetry.telemetryLevel` setting — either being off disables telemetry."
        },
        "skillsmith.telemetryEndpoint": {
          "type": "string",
          "default": "",
          "description": "Telemetry endpoint URL (leave empty to disable network calls). Events POST here as {event, anonymous_id, metadata}."
        },
        "skillsmith.demoMode": {
          "type": "boolean",
          "default": false,
          "description": "Show sample/demo skills when the Skillsmith server is unavailable. Off by default; intended for demos and screenshots only."
        },
        "skillsmith.cliPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the Skillsmith CLI executable. Leave empty for automatic detection. Set this if auto-detection fails because you use a non-standard Node version manager or custom npm prefix (e.g. /home/user/.nvm/versions/node/v20.19.1/bin/skillsmith)."
        },
        "skillsmith.inventoryAudit.deep": {
          "type": "boolean",
          "default": false,
          "description": "Run the deep semantic-overlap pass when auditing your skill inventory (Audit Skill Inventory). Detects semantic collisions beyond exact namespace clashes, but is slower. Off by default."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vscode-test",
    "test:e2e": "npm run test:e2e:setup && wdio run ./e2e/wdio.conf.ts",
    "test:e2e:setup": "node e2e/scripts/fix-minimatch-esm.mjs",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "package": "vsce package --no-dependencies",
    "package:check": "vsce package --no-dependencies --out skillsmith.vsix && node scripts/validate-vsix.mjs skillsmith.vsix && rm skillsmith.vsix"
  },
  "dependencies": {
    "cross-spawn": "7.0.6",
    "marked": "15.0.7",
    "sanitize-html": "2.17.4"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/mocha": "10.0.10",
    "@types/node": "^25.9.3",
    "@types/sanitize-html": "2.16.1",
    "@types/vscode": "1.110.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "3.9.2",
    "@wdio/cli": "9.29.0",
    "@wdio/local-runner": "9.29.0",
    "@wdio/mocha-framework": "9.29.0",
    "@wdio/spec-reporter": "9.29.0",
    "esbuild": "0.28.1",
    "typescript": "5.9.3",
    "vitest": "4.1.6",
    "wdio-vscode-service": "8.0.0"
  }
}
