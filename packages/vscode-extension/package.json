{
  "name": "skillsmith-vscode",
  "displayName": "Skillsmith",
  "description": "Discover and install agent skills directly in VS Code",
  "version": "0.2.1",
  "publisher": "skillsmith",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "skills",
    "ai",
    "mcp",
    "claude",
    "developer-tools",
    "productivity"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "license": "Elastic-2.0",
  "icon": "resources/skillsmith-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/smith-horn/skillsmith"
  },
  "homepage": "https://skillsmith.app",
  "bugs": {
    "url": "https://github.com/smith-horn/skillsmith/issues"
  },
  "galleryBanner": {
    "color": "#0d0d0f",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skillsmith.searchSkills",
        "title": "Search Skills",
        "category": "Skillsmith",
        "icon": "$(search)"
      },
      {
        "command": "skillsmith.installSkill",
        "title": "Install Skill",
        "category": "Skillsmith",
        "icon": "$(cloud-download)"
      },
      {
        "command": "skillsmith.refreshSkills",
        "title": "Refresh Skills",
        "category": "Skillsmith",
        "icon": "$(refresh)"
      },
      {
        "command": "skillsmith.viewSkillDetails",
        "title": "View Skill Details",
        "category": "Skillsmith"
      },
      {
        "command": "skillsmith.mcpReconnect",
        "title": "Connect/Reconnect to MCP Server",
        "category": "Skillsmith",
        "icon": "$(plug)"
      },
      {
        "command": "skillsmith.createSkill",
        "title": "Create Skill",
        "category": "Skillsmith",
        "icon": "$(add)"
      },
      {
        "command": "skillsmith.uninstallSkill",
        "title": "Uninstall Skill",
        "category": "Skillsmith",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skillsmith",
          "title": "Skillsmith",
          "icon": "resources/skillsmith.svg"
        }
      ]
    },
    "views": {
      "skillsmith": [
        {
          "id": "skillsmith.skillsView",
          "name": "Skills",
          "type": "tree"
        },
        {
          "id": "skillsmith.searchView",
          "name": "Search Results",
          "type": "tree",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "skillsmith.skillsView",
        "contents": "No skills installed yet.\n[Search Skills](command:skillsmith.searchSkills)\n[Create a Skill](command:skillsmith.createSkill)"
      }
    ],
    "walkthroughs": [
      {
        "id": "skillsmith.getStarted",
        "title": "Get Started with Skillsmith",
        "description": "Discover, install, and author Claude Code skills without leaving VS Code.",
        "steps": [
          {
            "id": "skillsmith.walkthrough.discover",
            "title": "Discover skills",
            "description": "Search the Skillsmith registry by keyword, category, or trust tier.\n[Search Skills](command:skillsmith.searchSkills)",
            "media": {
              "markdown": "resources/walkthrough/discover.md"
            }
          },
          {
            "id": "skillsmith.walkthrough.install",
            "title": "Install a skill",
            "description": "Install any skill to `~/.claude/skills` with one click from the Search Results view.\n[Open Skillsmith Sidebar](command:workbench.view.extension.skillsmith)",
            "media": {
              "markdown": "resources/walkthrough/install.md"
            }
          },
          {
            "id": "skillsmith.walkthrough.author",
            "title": "Create your own skill",
            "description": "Scaffold a new skill via the Skillsmith CLI — author, name, description, type.\n[Create Skill](command:skillsmith.createSkill)",
            "media": {
              "markdown": "resources/walkthrough/create.md"
            }
          }
        ]
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "skillsmith.searchSkills",
          "when": "view == skillsmith.skillsView",
          "group": "navigation"
        },
        {
          "command": "skillsmith.refreshSkills",
          "when": "view == skillsmith.skillsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "skillsmith.installSkill",
          "when": "view == skillsmith.searchView && viewItem == skill",
          "group": "inline"
        },
        {
          "command": "skillsmith.viewSkillDetails",
          "when": "viewItem == skill"
        },
        {
          "command": "skillsmith.uninstallSkill",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill",
          "group": "inline"
        },
        {
          "command": "skillsmith.uninstallSkill",
          "when": "view == skillsmith.skillsView && viewItem == installedSkill"
        }
      ]
    },
    "configuration": {
      "title": "Skillsmith",
      "properties": {
        "skillsmith.skillsDirectory": {
          "type": "string",
          "default": "~/.claude/skills",
          "description": "Directory where skills are installed"
        },
        "skillsmith.apiEndpoint": {
          "type": "string",
          "default": "",
          "description": "Custom API endpoint for skill search (leave empty for default)"
        },
        "skillsmith.mcp.serverCommand": {
          "type": "string",
          "default": "npx",
          "description": "Command to run the MCP server"
        },
        "skillsmith.mcp.serverArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "@skillsmith/mcp-server"
          ],
          "description": "Arguments for the MCP server command"
        },
        "skillsmith.mcp.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically connect to MCP server on extension activation"
        },
        "skillsmith.mcp.autoReconnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reconnect when connection is lost"
        },
        "skillsmith.mcp.connectionTimeout": {
          "type": "number",
          "default": 30000,
          "description": "Connection timeout in milliseconds"
        },
        "skillsmith.mcp.minServerVersion": {
          "type": "string",
          "default": "0.4.9",
          "description": "Minimum required @skillsmith/mcp-server version. When the connected server is older, an informational toast prompts to run `npm install -g @skillsmith/mcp-server@latest`. Non-blocking."
        },
        "skillsmith.telemetry.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Send anonymous usage telemetry. Also respects VS Code's global `telemetry.telemetryLevel` setting — either being off disables telemetry."
        },
        "skillsmith.telemetryEndpoint": {
          "type": "string",
          "default": "",
          "description": "Telemetry endpoint URL (leave empty to disable network calls). Events POST here as {event, anonymous_id, metadata}."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "lint": "eslint src --ext ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vscode-test",
    "package": "vsce package --no-dependencies",
    "package:check": "vsce package --no-dependencies --out skillsmith.vsix && node scripts/validate-vsix.mjs skillsmith.vsix && rm skillsmith.vsix"
  },
  "dependencies": {
    "cross-spawn": "7.0.6",
    "marked": "15.0.7",
    "sanitize-html": "2.14.0"
  },
  "devDependencies": {
    "@types/cross-spawn": "6.0.6",
    "@types/node": "^22.15.0",
    "@types/mocha": "10.0.10",
    "@types/sanitize-html": "2.13.0",
    "@types/vscode": "1.110.0",
    "@vscode/test-electron": "2.5.2",
    "@vscode/vsce": "2.32.0",
    "esbuild": "0.27.2",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
