{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.smith-horn/skillsmith",
  "title": "Skillsmith",
  "description": "Discover, install, and manage Claude Code skills via MCP with 14,000+ curated skills.",
  "websiteUrl": "https://skillsmith.app",
  "repository": {
    "url": "https://github.com/smith-horn/skillsmith",
    "source": "github"
  },
  "version": "0.4.12",
  "_meta": {
    "io.skillsmith/categories": ["developer-tools", "ai-agents", "skill-management"],
    "io.skillsmith/keywords": [
      "claude-code",
      "agent-skills",
      "skill-discovery",
      "autonomous-agents",
      "openclaw"
    ]
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@skillsmith/mcp-server",
      "version": "0.4.12",
      "transport": {
        "type": "stdio"
      },
      "runtime": {
        "type": "node",
        "minVersion": "22.0.0"
      }
    }
  ]
}
