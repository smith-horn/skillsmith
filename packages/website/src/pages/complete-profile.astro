    outline-offset: 2px;
  }
  .profile-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .profile-fieldset {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0;
    padding: 0;
    border: none;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .form-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: #d4d4d8;
  }
  .form-input {
    width: 100%;
    padding: 0.625rem 0.875rem;
    background: #0d0d0f;
