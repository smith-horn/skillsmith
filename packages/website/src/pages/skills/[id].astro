---
/**
 * Skills: Category Landing Pages + Skill Detail Pages
 *
 * SMI-3018 / SMI-2706: Single SSR route handles two cases:
 *   1. Known category slugs → category landing page with live skill grid + JSON-LD
 *   2. Everything else → individual skill detail page (client-side fetch)
 *
 * This avoids a route collision between [category].astro and [id].astro in SSR mode.
 * Edge cache for category pages: s-maxage=300, stale-while-revalidate=60
 */
import BaseLayout from '../../layouts/BaseLayout.astro'
import { CATEGORIES, type SkillItem } from '../../data/categories.js'

export const prerender = false

const { id } = Astro.params

const categoryMeta = CATEGORIES.find((c) => c.slug === id)
const isCategory = categoryMeta !== undefined

let categorySkills: SkillItem[] = []
let categoryFetchFailed = false

if (isCategory && categoryMeta) {
  try {
    const apiUrl = `https://api.skillsmith.app/v1/skills?category=${encodeURIComponent(categoryMeta.slug)}&limit=12&sort=score`
    const res = await fetch(apiUrl, { cache: 'default' })
    if (res.ok) {
      const data = (await res.json()) as { skills?: SkillItem[] }
      categorySkills = data.skills ?? []
    } else {
      categoryFetchFailed = true
    }
  } catch {
    categoryFetchFailed = true
  }
  Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=60')
}

function badgeClasses(tier: string): string {
  if (tier === 'verified')
    return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-500/20 text-emerald-400 flex-shrink-0'
  if (tier === 'community')
    return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/20 text-blue-400 flex-shrink-0'
  return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-dark-700 text-dark-400 flex-shrink-0'
}

// Build JSON-LD for category pages
const categoryJsonLd =
  isCategory && categoryMeta
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.skillsmith.app' },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Skills',
              item: 'https://www.skillsmith.app/skills',
            },
            {
              '@type': 'ListItem',
              position: 3,
              name: categoryMeta.label,
              item: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
            },
          ],
        },
        {
          '@context': 'https://schema.org',
          '@type': 'CollectionPage',
          name: `${categoryMeta.label} Skills — Skillsmith`,
          description: categoryMeta.metaDescription,
          url: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
          isPartOf: { '@id': 'https://www.skillsmith.app/#website' },
        },
        ...(categorySkills.length > 0
          ? [
              {
                '@context': 'https://schema.org',
                '@type': 'ItemList',
                name: `Top ${categoryMeta.label} Skills`,
                description: categoryMeta.jsonLdDescription,
                url: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
                itemListElement: categorySkills.map((s, i) => ({
                  '@type': 'ListItem',
                  position: i + 1,
                  name: s.name,
                  url: `https://www.skillsmith.app/skills/${encodeURIComponent(s.id)}`,
                  description: s.description,
                })),
              },
            ]
          : []),
      ]
    : null
---

{
  isCategory && categoryMeta && (
    <BaseLayout
      title={`${categoryMeta.label} Skills — Skillsmith`}
      description={categoryMeta.metaDescription}
    >
      {categoryJsonLd &&
        categoryJsonLd.map((ld) => (
          <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(ld)} />
        ))}
      <link
        rel="canonical"
        href={`https://www.skillsmith.app/skills/${categoryMeta.slug}/`}
        slot="head"
      />

      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center space-x-2 text-sm">
            <li>
              <a href="/" class="text-dark-500 hover:text-primary-400 transition-colors">
                Home
              </a>
            </li>
            <li class="text-dark-600" aria-hidden="true">
              /
            </li>
            <li>
              <a href="/skills" class="text-dark-500 hover:text-primary-400 transition-colors">
                Skills
              </a>
            </li>
            <li class="text-dark-600" aria-hidden="true">
              /
            </li>
            <li class="text-dark-300" aria-current="page">
              {categoryMeta.label}
            </li>
          </ol>
        </nav>

        <header class="mb-10">
          <h1 class="text-3xl sm:text-4xl font-bold mb-4">{categoryMeta.h1}</h1>
          <p class="text-lg text-dark-400 max-w-2xl">{categoryMeta.description}</p>
        </header>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href={`/skills?category=${categoryMeta.slug}`}
            class="inline-flex items-center px-6 py-3 bg-gradient-to-br from-[#E07A5F] to-[#D4694E] rounded-xl font-bold text-white shadow-cta hover:scale-[1.02] transition-all text-center focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:outline-none"
          >
            Browse {categoryMeta.label} skills &rarr;
          </a>
          <a
            href="/skills"
            class="inline-flex items-center px-6 py-3 border border-white/10 rounded-xl font-medium text-white hover:border-white/20 transition-colors text-center focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:outline-none"
          >
            All categories
          </a>
        </div>

        {!categoryFetchFailed && categorySkills.length > 0 && (
          <div class="mb-12">
            <h2 class="text-lg font-semibold mb-4">Top {categoryMeta.label} Skills</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {categorySkills.map((s) => (
                <a
                  href={`/skills/${encodeURIComponent(s.id)}`}
                  class="flex flex-col gap-2 p-4 rounded-xl border border-white/[0.06] hover:border-primary-400/40 bg-dark-900/40 hover:bg-dark-900 transition-all"
                >
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-white text-sm truncate">{s.name}</span>
                    <span class={badgeClasses(s.trust_tier)}>{s.trust_tier}</span>
                  </div>
                  <p class="text-xs text-dark-400 line-clamp-2">{s.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="bg-[#18181B] border border-white/[0.06] rounded-xl p-8">
          <h2 class="text-lg font-semibold mb-3">About {categoryMeta.label} Skills</h2>
          <p class="text-dark-400">{categoryMeta.description}</p>
          <p class="text-dark-500 text-sm mt-4">
            Skillsmith indexes 14,000+ curated skills from GitHub. Use the{' '}
            <a
              href={`/skills?category=${categoryMeta.slug}`}
              class="text-primary-400 hover:text-primary-300 underline underline-offset-2"
            >
              {categoryMeta.label.toLowerCase()} skills browser
            </a>{' '}
            to search, filter by trust tier, and install with one command.
          </p>
        </div>
      </div>
    </BaseLayout>
  )
}

{
  !isCategory && (
    <BaseLayout
      title="Skill Details"
      description="View skill details and installation instructions"
    >
      <div id="skill-page-config" data-skill-id={id} hidden />
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav class="mb-8">
          <ol class="flex items-center space-x-2 text-sm">
            <li>
              <a href="/" class="text-dark-500 hover:text-primary-400 transition-colors">
                Home
              </a>
            </li>
            <li class="text-dark-600">/</li>
            <li>
              <a href="/skills" class="text-dark-500 hover:text-primary-400 transition-colors">
                Skills
              </a>
            </li>
            <li class="text-dark-600">/</li>
            <li id="breadcrumb-name" class="text-dark-300">
              Loading...
            </li>
          </ol>
        </nav>

        <div id="loading-state" class="text-center py-20">
          <div class="inline-block animate-spin rounded-full h-12 w-12 border-2 border-primary-500 border-t-transparent" />
          <p class="text-dark-400 mt-6">Loading skill details...</p>
        </div>

        <div id="error-state" class="hidden text-center py-20">
          <svg
            class="w-20 h-20 mx-auto text-red-500 mb-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
          <h2 class="text-2xl font-bold text-dark-200 mb-2">Skill not found</h2>
          <p id="error-message" class="text-dark-500 mb-6">
            The requested skill could not be loaded.
          </p>
          <a
            href="/skills"
            class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 19l-7-7m0 0l7-7m-7 7h18"
              />
            </svg>
            Back to Skills
          </a>
        </div>

        <div id="skill-content" class="hidden">
          <div class="bg-dark-900 rounded-xl border border-dark-800 p-8 mb-8">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-6">
              <div class="flex-1">
                <div class="flex items-center gap-4 mb-4">
                  <h1 id="skill-name" class="text-3xl md:text-4xl font-bold text-white" />
                  <span
                    id="skill-trust-badge"
                    class="px-3 py-1 text-sm font-medium rounded-full border"
                  />
                </div>
                <p id="skill-author" class="text-dark-400 text-lg mb-2" />
                <p id="skill-version" class="text-dark-500" />
              </div>
              <div class="flex flex-col items-end gap-4">
                <div class="text-right">
                  <p class="text-dark-500 text-sm mb-1">Quality</p>
                  <p id="skill-tier" class="text-2xl font-bold" />
                  <p id="skill-stars" class="text-dark-500 text-sm" />
                </div>
              </div>
            </div>
          </div>

          <div class="bg-dark-900 rounded-xl border border-dark-800 p-8 mb-8">
            <h2 class="text-xl font-semibold text-white mb-4">Description</h2>
            <p id="skill-description" class="text-dark-300 leading-relaxed" />
          </div>

          <div
            id="skill-content-section"
            class="hidden bg-dark-900 rounded-xl border border-dark-800 p-8 mb-8"
          >
            <h2 class="text-xl font-semibold text-white mb-4">README</h2>
            <div
              id="skill-readme"
              class="text-dark-300 leading-relaxed whitespace-pre-wrap font-mono text-sm overflow-x-auto"
            />
          </div>

          <div class="bg-dark-900 rounded-xl border border-dark-800 p-8 mb-8">
            <div class="flex items-start justify-between gap-4 mb-4 flex-wrap">
              <h2 class="text-xl font-semibold text-white">Installation</h2>
              <a
                id="skill-source-link"
                data-smi="4840"
                href="#"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="View source on GitHub (opens in new tab)"
                class="hidden inline-flex items-center gap-1.5 px-3 py-1.5 text-sm text-dark-300 hover:text-white border border-dark-700 hover:border-primary-500/50 rounded-lg transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill-rule="evenodd"
                    clip-rule="evenodd"
                    d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
                  />
                </svg>
                <span>View source</span>
              </a>
            </div>
            <p class="text-dark-400 mb-4">
              Install this skill using the Skillsmith CLI or MCP server:
            </p>

            <div class="space-y-4">
              <div>
                <p class="text-dark-500 text-sm mb-2">Using npx (recommended):</p>
                <div class="relative">
                  <pre
                    id="install-command-npx"
                    class="bg-dark-950 rounded-lg p-4 text-sm font-mono text-primary-400 overflow-x-auto"
                  />
                  <button
                    class="copy-button absolute top-2 right-2 p-2 bg-dark-800 hover:bg-dark-700 rounded-lg text-dark-400 hover:text-white transition-colors"
                    data-target="install-command-npx"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                      />
                    </svg>
                  </button>
                </div>
              </div>

              <div>
                <p class="text-dark-500 text-sm mb-2">Using Skillsmith CLI:</p>
                <div class="relative">
                  <pre
                    id="install-command-cli"
                    class="bg-dark-950 rounded-lg p-4 text-sm font-mono text-primary-400 overflow-x-auto"
                  />
                  <button
                    class="copy-button absolute top-2 right-2 p-2 bg-dark-800 hover:bg-dark-700 rounded-lg text-dark-400 hover:text-white transition-colors"
                    data-target="install-command-cli"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                      />
                    </svg>
                  </button>
                </div>
              </div>

              <div>
                <p class="text-dark-500 text-sm mb-2">Or ask your assistant:</p>
                <div class="relative">
                  <pre
                    id="install-command-claude"
                    class="bg-dark-950 rounded-lg p-4 text-sm font-mono text-green-400 overflow-x-auto"
                  />
                  <button
                    class="copy-button absolute top-2 right-2 p-2 bg-dark-800 hover:bg-dark-700 rounded-lg text-dark-400 hover:text-white transition-colors"
                    data-target="install-command-claude"
                  >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"
                      />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div class="bg-dark-900 rounded-xl border border-dark-800 p-8">
              <h2 class="text-xl font-semibold text-white mb-6">Details</h2>
              <dl class="space-y-4">
                <div class="flex justify-between">
                  <dt class="text-dark-500">Category</dt>
                  <dd id="skill-category" class="text-dark-300" />
                </div>
                <div class="flex justify-between">
                  <dt class="text-dark-500">Trust Tier</dt>
                  <dd id="skill-trust-tier" class="text-dark-300" />
                </div>
                <div class="flex justify-between">
                  <dt class="text-dark-500">Version</dt>
                  <dd id="skill-version-detail" class="text-dark-300" />
                </div>
                <div id="downloads-row" class="flex justify-between hidden">
                  <dt class="text-dark-500">Downloads</dt>
                  <dd id="skill-downloads" class="text-dark-300" />
                </div>
                <div id="updated-row" class="flex justify-between hidden">
                  <dt class="text-dark-500">Last Updated</dt>
                  <dd id="skill-updated" class="text-dark-300" />
                </div>
              </dl>
            </div>

            <div class="bg-dark-900 rounded-xl border border-dark-800 p-8">
              <h2 class="text-xl font-semibold text-white mb-6">Tags</h2>
              <div id="skill-tags" class="flex flex-wrap gap-2" />
              <p id="no-tags" class="text-dark-500 hidden">
                No tags available
              </p>
            </div>
          </div>

          <div
            id="also-installed-section"
            class="bg-dark-900 rounded-xl border border-dark-800 p-8 mb-8 hidden"
          >
            <h2 class="text-xl font-semibold text-white mb-6">Users Also Installed</h2>
            <div
              id="also-installed-skills"
              class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"
            />
          </div>

          <div
            id="related-section"
            class="bg-dark-900 rounded-xl border border-dark-800 p-8 hidden"
          >
            <h2 class="text-xl font-semibold text-white mb-6">Related Skills</h2>
            <div id="related-skills" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4" />
          </div>
        </div>
      </div>
    </BaseLayout>
  )
}

<script>
  export const API_BASE = `${import.meta.env.PUBLIC_API_BASE_URL ?? 'https://api.skillsmith.app'}/functions/v1`
</script>
