---
/**
 * Skills: Category Landing Pages + Skill Detail Pages
 *
 * SMI-3018 / SMI-2706: Single SSR route handles two cases:
 *   1. Known category slugs → category landing page with live skill grid + JSON-LD
 *   2. Everything else → individual skill detail page (client-side fetch)
 *
 * This avoids a route collision between [category].astro and [id].astro in SSR mode.
 * Edge cache for category pages: s-maxage=300, stale-while-revalidate=60
 */
import BaseLayout from '../../layouts/BaseLayout.astro'

export const prerender = false

const { id } = Astro.params

// ─── Category Landing Page Logic (SMI-3018) ──────────────────────────────────

interface CategoryMeta {
  slug: string
  label: string
  h1: string
  metaDescription: string
  description: string
  jsonLdDescription: string
}

interface SkillItem {
  id: string
  name: string
  description: string
  trust_tier: string
}

const CATEGORIES: CategoryMeta[] = [
  {
    slug: 'development',
    label: 'Development',
    h1: 'Development Skills for Claude Code',
    metaDescription:
      'Browse 14,000+ development skills for Claude Code. Code generation, refactoring, PR reviews, and IDE integrations. Free to try.',
    description:
      'Skills for software development workflows — code generation, refactoring, PR reviews, and IDE integrations that make Claude Code a better coding partner.',
    jsonLdDescription:
      'Claude Code skills for software development workflows including code generation, refactoring, and PR reviews.',
  },
  {
    slug: 'integrations',
    label: 'Integrations',
    h1: 'Integration Skills — MCP Servers & APIs',
    metaDescription:
      'Connect Claude Code to your tools. Browse MCP server skills, API integrations, and protocol implementations. Free to try.',
    description:
      'MCP servers, API integrations, and protocol implementations that connect Claude Code to your existing tools and services.',
    jsonLdDescription:
      'Claude Code skills for MCP servers, API integrations, and protocol implementations.',
  },
  {
    slug: 'testing',
    label: 'Testing',
    h1: 'Testing Skills for Claude Code',
    metaDescription:
      'Automate your tests with Claude Code. Browse skills for Vitest, Jest, Playwright, and more testing frameworks. Free to try.',
    description:
      'Testing frameworks and utilities for unit, integration, and end-to-end test automation across all major testing tools.',
    jsonLdDescription:
      'Claude Code skills for automated testing including unit tests, integration tests, and end-to-end test automation.',
  },
  {
    slug: 'devops',
    label: 'DevOps',
    h1: 'DevOps Skills for Claude Code',
    metaDescription:
      'Automate your DevOps pipelines. Browse skills for Docker, CI/CD, Kubernetes, and infrastructure tools. Free to try.',
    description:
      'CI/CD, Docker, Kubernetes, and infrastructure automation skills for DevOps workflows and deployment pipelines.',
    jsonLdDescription:
      'Claude Code skills for DevOps including CI/CD automation, Docker, Kubernetes, and infrastructure management.',
  },
  {
    slug: 'documentation',
    label: 'Documentation',
    h1: 'Documentation Skills for Claude Code',
    metaDescription:
      'Generate docs automatically with Claude Code. Browse skills for changelogs, API docs, and README generation. Free to try.',
    description:
      'Documentation generation, changelog automation, and API doc skills that keep your docs current with your code.',
    jsonLdDescription:
      'Claude Code skills for documentation generation including changelogs, API docs, and README automation.',
  },
  {
    slug: 'productivity',
    label: 'Productivity',
    h1: 'Productivity Skills for Claude Code',
    metaDescription:
      'Work smarter with Claude Code. Browse skills for workflow automation, task management, and developer productivity. Free to try.',
    description:
      'Workflow automation, task management, and productivity skills for developers who want to move faster on every task.',
    jsonLdDescription:
      'Claude Code skills for developer productivity including workflow automation and task management.',
  },
  {
    slug: 'security',
    label: 'Security',
    h1: 'Security Skills for Claude Code',
    metaDescription:
      'Harden your codebase with Claude Code. Browse skills for security scanning, vulnerability detection, and compliance. Free to try.',
    description:
      'Security scanning, vulnerability detection, and compliance skills that help you build secure by default.',
    jsonLdDescription:
      'Claude Code skills for security scanning, vulnerability detection, and compliance automation.',
  },
]

const categoryMeta = CATEGORIES.find((c) => c.slug === id)
const isCategory = categoryMeta !== undefined

let categorySkills: SkillItem[] = []
let categoryFetchFailed = false

if (isCategory && categoryMeta) {
  try {
    const apiUrl = `https://api.skillsmith.app/v1/skills?category=${encodeURIComponent(categoryMeta.slug)}&limit=12&sort=score`
    const res = await fetch(apiUrl, { cache: 'default' })
    if (res.ok) {
      const data = (await res.json()) as { skills?: SkillItem[] }
      categorySkills = data.skills ?? []
    } else {
      categoryFetchFailed = true
    }
  } catch {
    categoryFetchFailed = true
  }
  Astro.response.headers.set('Cache-Control', 's-maxage=300, stale-while-revalidate=60')
}

function badgeClasses(tier: string): string {
  if (tier === 'verified')
    return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-emerald-500/20 text-emerald-400 flex-shrink-0'
  if (tier === 'community')
    return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-blue-500/20 text-blue-400 flex-shrink-0'
  return 'px-1.5 py-0.5 rounded text-[10px] font-medium bg-dark-700 text-dark-400 flex-shrink-0'
}

// Build JSON-LD for category pages
const categoryJsonLd =
  isCategory && categoryMeta
    ? [
        {
          '@context': 'https://schema.org',
          '@type': 'BreadcrumbList',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.skillsmith.app' },
            {
              '@type': 'ListItem',
              position: 2,
              name: 'Skills',
              item: 'https://www.skillsmith.app/skills',
            },
            {
              '@type': 'ListItem',
              position: 3,
              name: categoryMeta.label,
              item: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
            },
          ],
        },
        {
          '@context': 'https://schema.org',
          '@type': 'CollectionPage',
          name: `${categoryMeta.label} Skills — Skillsmith`,
          description: categoryMeta.metaDescription,
          url: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
          isPartOf: { '@id': 'https://www.skillsmith.app/#website' },
        },
        ...(categorySkills.length > 0
          ? [
              {
                '@context': 'https://schema.org',
                '@type': 'ItemList',
                name: `Top ${categoryMeta.label} Skills`,
                description: categoryMeta.jsonLdDescription,
                url: `https://www.skillsmith.app/skills/${categoryMeta.slug}`,
                itemListElement: categorySkills.map((s, i) => ({
                  '@type': 'ListItem',
                  position: i + 1,
                  name: s.name,
                  url: `https://www.skillsmith.app/skills/${encodeURIComponent(s.id)}`,
                  description: s.description,
                })),
              },
            ]
          : []),
      ]
    : null
---

{
  isCategory && categoryMeta && (
    <BaseLayout
      title={`${categoryMeta.label} Skills — Skillsmith`}
      description={categoryMeta.metaDescription}
    >
      {categoryJsonLd &&
        categoryJsonLd.map((ld) => (
          <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify(ld)} />
        ))}
      <link
        rel="canonical"
        href={`https://www.skillsmith.app/skills/${categoryMeta.slug}`}
        slot="head"
      />

      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav aria-label="Breadcrumb" class="mb-8">
          <ol class="flex items-center space-x-2 text-sm">
            <li>
              <a href="/" class="text-dark-500 hover:text-primary-400 transition-colors">
                Home
              </a>
            </li>
            <li class="text-dark-600" aria-hidden="true">
              /
            </li>
            <li>
              <a href="/skills" class="text-dark-500 hover:text-primary-400 transition-colors">
                Skills
              </a>
            </li>
            <li class="text-dark-600" aria-hidden="true">
              /
            </li>
            <li class="text-dark-300" aria-current="page">
              {categoryMeta.label}
            </li>
          </ol>
        </nav>

        <header class="mb-10">
          <h1 class="text-3xl sm:text-4xl font-bold mb-4">{categoryMeta.h1}</h1>
          <p class="text-lg text-dark-400 max-w-2xl">{categoryMeta.description}</p>
        </header>

        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a
            href={`/skills?category=${categoryMeta.slug}`}
            class="inline-flex items-center px-6 py-3 bg-gradient-to-br from-[#E07A5F] to-[#D4694E] rounded-xl font-bold text-white shadow-cta hover:scale-[1.02] transition-all text-center focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:outline-none"
          >
            Browse {categoryMeta.label} skills &rarr;
          </a>
          <a
            href="/skills"
            class="inline-flex items-center px-6 py-3 border border-white/10 rounded-xl font-medium text-white hover:border-white/20 transition-colors text-center focus-visible:ring-2 focus-visible:ring-primary-400 focus-visible:outline-none"
          >
            All categories
          </a>
        </div>

        {!categoryFetchFailed && categorySkills.length > 0 && (
          <div class="mb-12">
            <h2 class="text-lg font-semibold mb-4">Top {categoryMeta.label} Skills</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {categorySkills.map((s) => (
                <a
                  href={`/skills/${encodeURIComponent(s.id)}`}
                  class="flex flex-col gap-2 p-4 rounded-xl border border-white/[0.06] hover:border-primary-400/40 bg-dark-900/40 hover:bg-dark-900 transition-all"
                >
                  <div class="flex items-center gap-2">
                    <span class="font-semibold text-white text-sm truncate">{s.name}</span>
                    <span class={badgeClasses(s.trust_tier)}>{s.trust_tier}</span>
                  </div>
                  <p class="text-xs text-dark-400 line-clamp-2">{s.description}</p>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="bg-[#18181B] border border-white/[0.06] rounded-xl p-8">
          <h2 class="text-lg font-semibold mb-3">About {categoryMeta.label} Skills</h2>
          <p class="text-dark-400">{categoryMeta.description}</p>
          <p class="text-dark-500 text-sm mt-4">
            Skillsmith indexes 14,000+ curated skills from GitHub. Use the{' '}
            <a
              href={`/skills?category=${categoryMeta.slug}`}
              class="text-primary-400 hover:text-primary-300 underline underline-offset-2"
            >
              {categoryMeta.label.toLowerCase()} skills browser
            </a>{' '}
            to search, filter by trust tier, and install with one command.
          </p>
        </div>
      </div>
    </BaseLayout>
  )
}

{
  !isCategory && (
    <BaseLayout
      title="Skill Details"
      description="View skill details and installation instructions"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <nav class="mb-8">
          <ol class="flex items-center space-x-2 text-sm">
            <li>
              <a href="/" class="text-dark-500 hover:text-primary-400 transition-colors">
                Home
              </a>
            </li>
            <li class="text-dark-600">/</li>
            <li>
              <a href="/skills" class="text-dark-500 hover:text-primary-400 transition-colors">
                Skills
              </a>
            </li>
            <li class="text-dark-600">/</li>
            <li id="breadcrumb-name" class="text-dark-300">
              Loading...
            </li>
          </ol>
        </nav>

        <div id="loading-state" class="text-center py-20">
          <div class="inline-block animate-spin rounded-full h-12 w-12 border-2 border-primary-500 border-t-transparent" />
          <p class="text-dark-400 mt-6">Loading skill details...</p>
        </div>

        <div id="error-state" class="hidden text-center py-20">
          <svg
            class="w-20 h-20 mx-auto text-red-500 mb-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
          <h2 class="text-2xl font-bold text-dark-200 mb-2">Skill not found</h2>
          <p id="error-message" class="text-dark-500 mb-6">
            The requested skill could not be loaded.
          </p>
          <a
            href="/skills"
            class="inline-flex items-center px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 19l-7-7m0 0l7-7m-7 7h18"
              />
