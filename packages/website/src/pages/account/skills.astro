---
/**
 * /account/skills — Cross-machine Skill Inventory (SMI-5393, umbrella SMI-5382)
 *
 * Read-only monitoring page. Fetches `get_user_inventory()` RPC rows client-side,
 * builds a DeviceView via inventory-view.ts, and renders by empty-state:
 *   consent-off | opted-in-no-devices | single-machine | populated
 *
 * Auth: Supabase session (redirects unauthenticated users to /login).
 * No browser→machine control — display only.
 *
 * Builder helpers + dynamic CSS live in lib/skills-page-render.ts (<500 line split).
 */

export const prerender = false

import { ClientRouter } from 'astro:transitions'
import { getSupabaseConfig } from '../../lib/supabase-config'
import Footer from '../../components/Footer.astro'
import Nav from '../../components/Nav.astro'

const supabaseConfig = getSupabaseConfig()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/logo-icon.svg" />
    <meta
      name="description"
      content="View your installed Skillsmith skills across all your machines"
    />
    <title>Skill Inventory | Skillsmith</title>
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700,900&display=swap"
      rel="stylesheet"
    />
    <script is:inline define:vars={{ supabaseConfig }}>
      window.__SUPABASE_CONFIG__ = supabaseConfig
    </script>
    <ClientRouter />
  </head>
  <body>
    <Nav activePath="/account" />

    <main class="page-container">
      <div id="loading-state" class="state-block">
        <svg class="spinner" viewBox="0 0 24 24" aria-hidden="true">
          <circle
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"
            fill="none"
            opacity="0.25"></circle>
          <path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="4" fill="none"
          ></path>
        </svg>
        <p>Loading inventory...</p>
      </div>

      <div id="error-state" class="state-block" style="display: none;">
        <p id="error-message" class="error-text">Something went wrong.</p>
        <button type="button" data-action="reload" class="btn btn-primary">Try Again</button>
      </div>

      <div id="page-content" style="display: none;">
        <div class="page-header">
          <a href="/account" class="back-link">&larr; Account</a>
          <h1>Skill Inventory</h1>
          <p class="page-description">
            A read-only view of the skills installed across your machines. Push from each machine
            with <code>skillsmith inventory push</code>.
          </p>
        </div>

        <!-- State: consent-off -->
        <div id="state-consent-off" class="card" style="display: none;">
          <h2>Cross-machine inventory is off.</h2>
          <p class="state-body">
            Enable inventory sync on the
            <a href="/account/telemetry" class="inline-link">Telemetry Preferences</a> page to see your
            skills across machines. When enabled, Skillsmith uploads a one-way hash of your hostname,
            your OS platform, and per-skill metadata (name, version, content hash) — never file contents
            or paths.
          </p>
        </div>

        <!-- State: opted-in-no-devices -->
        <div id="state-opted-in-no-devices" class="card" style="display: none;">
          <h2>Inventory sync is on.</h2>
          <p class="state-body">Run this on each machine to push your installed skills:</p>
          <div class="command-block">
            <code class="command-code">skillsmith inventory push</code>
            <button
              id="copy-command-btn"
              type="button"
              class="btn btn-secondary btn-sm"
              aria-label="Copy command to clipboard">Copy</button
            >
          </div>
          <p id="copy-status" role="status" aria-live="polite" class="copy-status"></p>
        </div>

        <!-- State: single-machine hint (shown above devices) -->
        <div id="single-machine-hint" class="inline-hint" style="display: none;">
          Push from another machine to compare your skills across machines.
        </div>

        <!-- Populated device list — built client-side by skills-page-render.ts -->
        <div id="devices-container"></div>

        <!-- Always visible inside content: reload affordance -->
        <div class="reload-row">
          <button type="button" data-action="reload" class="btn btn-secondary">
            Reload this view
          </button>
          <p class="reload-description">
            This reloads what your machines last reported — there is no way to push changes back to
            a machine from here.
          </p>
        </div>
      </div>
    </main>

    <Footer compact />
  </body>
</html>

<script>
  import { buildInventoryView, detectEmptyState } from '../../lib/inventory-view'
  import type { InventoryRow } from '../../lib/inventory-view'
  import { getSupabaseClient } from '../../lib/supabase-client'
  import { buildDeviceCardHtml, injectSkillsPageStyles } from '../../lib/skills-page-render'

  document.addEventListener('astro:page-load', async () => {
    // Pathname guard — listeners persist across ClientRouter navigations (SMI-5158).
    if (
      window.location.pathname !== '/account/skills' &&
      window.location.pathname !== '/account/skills/'
    )
      return

    // Inject CSS for dynamically-built device card elements (idempotent).
    injectSkillsPageStyles()

    const loadingEl = document.getElementById('loading-state')
    const errorEl = document.getElementById('error-state')
    const errorMsgEl = document.getElementById('error-message')
    const pageEl = document.getElementById('page-content')

    function showError(msg: string): void {
      if (loadingEl) loadingEl.style.display = 'none'
      if (pageEl) pageEl.style.display = 'none'
      if (errorEl) errorEl.style.display = 'flex'
      if (errorMsgEl) errorMsgEl.textContent = msg
    }

    // Bind reload handlers (error "Try Again" + content "Reload this view").
    document.querySelectorAll<HTMLButtonElement>('[data-action="reload"]').forEach((btn) => {
      btn.addEventListener('click', () => window.location.reload())
    })

    const supabase = getSupabaseClient()
    if (!supabase) {
      showError('Auth service not configured.')
      return
    }

    const {
      data: { session },
    } = await supabase.auth.getSession()
    if (!session) {
      window.location.href = '/login?next=/account/skills'
      return
    }

    const user = session.user

    // Parallel fetch: consent preference + inventory rows.
    const [consentResult, invResult] = await Promise.all([
      supabase
        .from('user_telemetry_preferences')
        .select('inventory_sync_enabled')
        .eq('user_id', user.id)
        .maybeSingle(),
      supabase.rpc('get_user_inventory'),
    ])

    if (invResult.error) {
      showError('Could not load inventory. Check your connection and try again.')
      return
    }

    const consentEnabled = (consentResult.data?.inventory_sync_enabled as boolean | null) ?? false
    const rows = (invResult.data as InventoryRow[]) ?? []
    const devices = buildInventoryView(rows)
    const emptyState = detectEmptyState(consentEnabled, devices.length)

    if (loadingEl) loadingEl.style.display = 'none'
    if (pageEl) pageEl.style.display = 'block'

    const consentOffEl = document.getElementById('state-consent-off')
    const noDevicesEl = document.getElementById('state-opted-in-no-devices')
    const hintEl = document.getElementById('single-machine-hint')
    const devContainer = document.getElementById('devices-container')

    if (consentOffEl) consentOffEl.style.display = emptyState === 'consent-off' ? 'block' : 'none'
    if (noDevicesEl)
      noDevicesEl.style.display = emptyState === 'opted-in-no-devices' ? 'block' : 'none'
    if (hintEl) hintEl.style.display = emptyState === 'single-machine' ? 'block' : 'none'

    if (devContainer && (emptyState === 'single-machine' || emptyState === 'populated')) {
      devContainer.innerHTML = devices.map(buildDeviceCardHtml).join('')
    }

    // Copy-command button (opted-in-no-devices state).
    const copyBtn = document.getElementById('copy-command-btn')
    const copyStatus = document.getElementById('copy-status')
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText('skillsmith inventory push')
          if (copyStatus) copyStatus.textContent = 'Copied!'
          setTimeout(() => {
            if (copyStatus) copyStatus.textContent = ''
          }, 2000)
        } catch {
          if (copyStatus) copyStatus.textContent = 'Copy failed — please copy manually.'
        }
      })
    }
  })
</script>

<style>
  body {
    margin: 0;
    background: #0a0a0c;
    color: #fafafa;
    font-family:
      'Satoshi',
      -apple-system,
      BlinkMacSystemFont,
      sans-serif;
    min-height: 100vh;
  }

  .page-container {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .state-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    gap: 1rem;
    color: #71717a;
  }

  .spinner {
    width: 40px;
    height: 40px;
    animation: spin 0.8s linear infinite;
    color: #7c3aed;
  }

  @keyframes spin {
    to {
      transform: rotate(360deg);
    }
  }

  .error-text {
    color: #ef4444;
    font-size: 0.875rem;
    margin: 0 0 1rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    color: #71717a;
    text-decoration: none;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: #fafafa;
  }

  .page-header h1 {
    font-size: 1.875rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    line-height: 1.2;
  }

  .page-description {
    color: #a1a1aa;
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .page-description code {
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 4px;
    padding: 0.1em 0.4em;
    font-size: 0.875em;
    color: #a78bfa;
  }

  .card {
    background: #111114;
    border: 1px solid #27272a;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .card h2 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: #fafafa;
  }

  .state-body {
    color: #a1a1aa;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  .inline-link {
    color: #a78bfa;
    text-decoration: none;
  }

  .inline-link:hover {
    text-decoration: underline;
  }

  .command-block {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #18181b;
    border: 1px solid #27272a;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin: 1rem 0 0.5rem;
    flex-wrap: wrap;
  }

  .command-code {
    flex: 1;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: 0.9rem;
    color: #a78bfa;
    word-break: break-all;
  }

  .copy-status {
    font-size: 0.8125rem;
    color: #10b981;
    margin: 0;
    min-height: 1.25rem;
  }

  .inline-hint {
    background: #18181b;
    border: 1px solid #27272a;
    border-left: 3px solid #7c3aed;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    font-size: 0.875rem;
    color: #a1a1aa;
  }

  .reload-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid #27272a;
  }

  .reload-description {
    flex: 1;
    min-width: 200px;
    font-size: 0.8125rem;
    color: #71717a;
    margin: 0;
    line-height: 1.5;
    padding-top: 0.375rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.25rem;
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    border: 1px solid transparent;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.8125rem;
  }

  .btn-primary {
    background: #7c3aed;
    color: #fafafa;
    border-color: #7c3aed;
  }

  .btn-primary:hover {
    background: #6d28d9;
    border-color: #6d28d9;
  }

  .btn-secondary {
    background: #18181b;
    color: #d4d4d8;
    border-color: #3f3f46;
  }

  .btn-secondary:hover {
    background: #27272a;
    color: #fafafa;
  }
</style>
