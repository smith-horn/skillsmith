---
/**
 * Team Workspaces
 *
 * @see SMI-3897: Team Admin Dashboard (Wave 2b)
 *
 * Shows: workspace cards with name, description, skill count.
 * Placeholder data with TODO comments for Supabase integration.
 */

export const prerender = false

import { ClientRouter } from 'astro:transitions'
import Footer from '../../../components/Footer.astro'
import Nav from '../../../components/Nav.astro'
import TeamNav from '../../../components/TeamNav.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/logo-icon.svg" />
    <meta name="description" content="Manage team workspaces" />
    <title>Team Workspaces | Skillsmith</title>
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700,900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <Nav activePath="/account/team" />

    <main class="workspaces-container">
      <h1>Team Workspaces</h1>

      <TeamNav activePath="/account/team/workspaces" />

      <section class="section">
        <div class="section-header">
          <h2>Workspaces (2)</h2>
          <!-- TODO: Wire create button to Supabase team_workspace create RPC -->
          <button class="btn btn-primary" id="create-workspace-btn" disabled>
            Create Workspace
          </button>
        </div>

        <!-- TODO: Replace placeholder data with Supabase workspace query -->
        <div class="workspace-grid">
          <div class="workspace-card">
            <div class="workspace-header">
              <h3 class="workspace-name">Frontend Tools</h3>
              <span class="workspace-badge">5 skills</span>
            </div>
            <p class="workspace-description">
              Shared skills for the frontend team: React best practices, accessibility auditing,
              performance optimization.
            </p>
            <div class="workspace-meta">
              <span class="workspace-owner">Created by alice@example.com</span>
              <span class="workspace-date">Jan 15, 2026</span>
            </div>
            <div class="workspace-skills">
              <span class="skill-tag">react-best-practices</span>
              <span class="skill-tag">accessibility</span>
              <span class="skill-tag">performance</span>
              <span class="skill-tag">+2 more</span>
            </div>
          </div>

          <div class="workspace-card">
            <div class="workspace-header">
              <h3 class="workspace-name">Backend Tools</h3>
              <span class="workspace-badge">7 skills</span>
            </div>
            <p class="workspace-description">
              Server-side development skills: Docker optimization, CI/CD, security auditing,
              database patterns.
            </p>
            <div class="workspace-meta">
              <span class="workspace-owner">Created by bob@example.com</span>
              <span class="workspace-date">Feb 3, 2026</span>
            </div>
            <div class="workspace-skills">
              <span class="skill-tag">docker-optimizer</span>
              <span class="skill-tag">ci-doctor</span>
              <span class="skill-tag">security-auditor</span>
              <span class="skill-tag">+4 more</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Empty state for teams with no workspaces -->
      <!-- Shown when workspace count is 0; hidden when workspaces exist -->
      <section class="section empty-section" style="display: none;" id="empty-state">
        <div class="empty-state">
          <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          <h3>No workspaces yet</h3>
          <p>Create a workspace to start sharing skills with your team.</p>
        </div>
      </section>
    </main>

    <Footer compact />
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      'Satoshi',
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Roboto,
      sans-serif;
    line-height: 1.6;
    color: #fafafa;
    background: #0d0d0f;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .workspaces-container {
    flex: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  .workspaces-container h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .section {
    background: #121214;
    border: 1px solid #2a2a2f;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin-bottom: 0;
  }

  .btn {
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition:
      background 0.15s,
      opacity 0.15s;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: #b8523a;
    color: #fafafa;
  }

  .btn-primary:hover:not(:disabled) {
    background: #a04530;
  }

  .workspace-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1rem;
  }

  .workspace-card {
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 0.75rem;
    padding: 1.25rem;
    transition: border-color 0.15s;
  }

  .workspace-card:hover {
    border-color: #3a3a42;
  }

  .workspace-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .workspace-name {
    font-size: 1rem;
    font-weight: 600;
  }

  .workspace-badge {
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(184, 82, 58, 0.15);
    color: #e07a5f;
  }

  .workspace-description {
    color: #9ca3af;
    font-size: 0.875rem;
    margin-bottom: 0.75rem;
    line-height: 1.5;
  }

  .workspace-meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.8125rem;
    color: #6b7280;
    margin-bottom: 0.75rem;
  }

  .workspace-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .skill-tag {
    padding: 0.1875rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.75rem;
    background: #2a2a2f;
    color: #9ca3af;
  }

  .empty-section {
    text-align: center;
  }

  .empty-state {
    padding: 2rem 1rem;
    color: #9ca3af;
  }

  .empty-icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1rem;
    color: #6b7280;
  }

  .empty-state h3 {
    color: #fafafa;
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .empty-state p {
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .workspace-grid {
      grid-template-columns: 1fr;
    }

    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }
</style>
