---
/**
 * Team Member Management
 *
 * @see SMI-3897: Team Admin Dashboard (Wave 2b)
 *
 * Shows: member list with roles (owner/admin/member), invite button placeholder.
 * Placeholder data with TODO comments for Supabase integration.
 */

export const prerender = false

import { ClientRouter } from 'astro:transitions'
import Footer from '../../../components/Footer.astro'
import Nav from '../../../components/Nav.astro'
import TeamNav from '../../../components/TeamNav.astro'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/logo-icon.svg" />
    <meta name="description" content="Manage team members" />
    <title>Team Members | Skillsmith</title>
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,700,900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body>
    <Nav activePath="/account/team" />

    <main class="members-container">
      <h1>Team Members</h1>

      <TeamNav activePath="/account/team/members" />

      <section class="section">
        <div class="section-header">
          <h2>Members (4)</h2>
          <!-- TODO: Wire invite button to Supabase team invite RPC -->
          <button class="btn btn-primary" id="invite-btn" disabled>Invite Member</button>
        </div>

        <!-- TODO: Replace placeholder data with Supabase team members query -->
        <div class="member-list">
          <div class="member-card">
            <div class="member-info">
              <div class="member-avatar">A</div>
              <div class="member-details">
                <div class="member-name">Alice Johnson</div>
                <div class="member-email">alice@example.com</div>
              </div>
            </div>
            <div class="member-meta">
              <span class="role-badge role-owner">Owner</span>
              <span class="member-joined">Joined Jan 2026</span>
            </div>
          </div>

          <div class="member-card">
            <div class="member-info">
              <div class="member-avatar">B</div>
              <div class="member-details">
                <div class="member-name">Bob Smith</div>
                <div class="member-email">bob@example.com</div>
              </div>
            </div>
            <div class="member-meta">
              <span class="role-badge role-admin">Admin</span>
              <span class="member-joined">Joined Feb 2026</span>
            </div>
          </div>

          <div class="member-card">
            <div class="member-info">
              <div class="member-avatar">C</div>
              <div class="member-details">
                <div class="member-name">Carol Davis</div>
                <div class="member-email">carol@example.com</div>
              </div>
            </div>
            <div class="member-meta">
              <span class="role-badge role-member">Member</span>
              <span class="member-joined">Joined Mar 2026</span>
            </div>
          </div>

          <div class="member-card">
            <div class="member-info">
              <div class="member-avatar">D</div>
              <div class="member-details">
                <div class="member-name">Dave Wilson</div>
                <div class="member-email">dave@example.com</div>
              </div>
            </div>
            <div class="member-meta">
              <span class="role-badge role-member">Member</span>
              <span class="member-joined">Joined Mar 2026</span>
            </div>
          </div>
        </div>
      </section>

      <!-- TODO: Wire pending invites section to Supabase -->
      <section class="section">
        <h2>Pending Invites</h2>
        <div class="empty-state">
          <p>No pending invitations.</p>
          <p class="text-muted">
            Invite team members to collaborate on shared workspaces and skills.
          </p>
        </div>
      </section>
    </main>

    <Footer compact />
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family:
      'Satoshi',
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      Roboto,
      sans-serif;
    line-height: 1.6;
    color: #fafafa;
    background: #0d0d0f;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .members-container {
    flex: 1;
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  .members-container h1 {
    font-size: 1.75rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .section {
    background: #121214;
    border: 1px solid #2a2a2f;
    border-radius: 0.75rem;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .section h2 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin-bottom: 0;
  }

  .btn {
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    border: none;
    cursor: pointer;
    transition:
      background 0.15s,
      opacity 0.15s;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-primary {
    background: #b8523a;
    color: #fafafa;
  }

  .btn-primary:hover:not(:disabled) {
    background: #a04530;
  }

  .member-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .member-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 1px solid #2a2a2f;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .member-card:last-child {
    border-bottom: none;
  }

  .member-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .member-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: #2a2a2f;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.875rem;
    color: #9ca3af;
    flex-shrink: 0;
  }

  .member-name {
    font-weight: 500;
    font-size: 0.9375rem;
  }

  .member-email {
    color: #9ca3af;
    font-size: 0.8125rem;
  }

  .member-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .role-badge {
    padding: 0.25rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  .role-owner {
    background: rgba(224, 122, 95, 0.2);
    color: #e07a5f;
  }

  .role-admin {
    background: rgba(139, 92, 246, 0.2);
    color: #a78bfa;
  }

  .role-member {
    background: rgba(107, 114, 128, 0.2);
    color: #9ca3af;
  }

  .member-joined {
    color: #6b7280;
    font-size: 0.8125rem;
  }

  .empty-state {
    text-align: center;
    padding: 1.5rem;
    color: #9ca3af;
  }

  .text-muted {
    color: #6b7280;
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 640px) {
    .section-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .member-meta {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
