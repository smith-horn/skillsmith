{
  "$schema": "https://json.schemastore.org/mcp.json",
  "mcpServers": {
    "skillsmith": {
      "command": "node",
      "args": ["./packages/mcp-server/dist/src/index.js"]
    },
    "ruflo": {
      "type": "stdio",
      "command": "npx",
      "args": ["ruflo@latest", "mcp", "start"],
      "env": {
        "CLAUDE_FLOW_LOG_LEVEL": "info",
        "CLAUDE_FLOW_MEMORY_BACKEND": "sqlite"
      }
    }
  }
}
