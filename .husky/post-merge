#!/bin/sh
# Post-merge hook
# - SMI-2552: Auto-install npm dependencies when package-lock.json changes
# - SMI-5343: Also run/advise a HOST npm install (feeds host tooling + worktree
#             symlinks) alongside the existing Docker path.
# Fires after git pull (merge) and git merge. Non-blocking — cannot abort.

# Color codes (match pre-commit style)
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

DOCKER_CONTAINER="skillsmith-dev-1"

# Check if package-lock.json changed in the merge
# ORIG_HEAD = tip before merge, HEAD = after merge
if git diff --name-only ORIG_HEAD HEAD | grep -q '^package-lock\.json$'; then
  echo ""
  echo "${BLUE}=== Post-Merge: package-lock.json changed ===${NC}"
  echo ""

  # --- Docker path (SMI-2552, unchanged) -------------------------------------
  if command -v docker > /dev/null 2>&1 && \
     docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${DOCKER_CONTAINER}$"; then
    echo "${YELLOW}Installing updated dependencies in Docker...${NC}"
    if docker exec -w /app "$DOCKER_CONTAINER" npm install; then
      echo "${GREEN}  Docker dependencies updated successfully.${NC}"
    else
      echo "${YELLOW}  Docker npm install failed. Run manually:${NC}"
      echo "    docker exec $DOCKER_CONTAINER npm install"
    fi
  else
    echo "${YELLOW}Docker container '${DOCKER_CONTAINER}' is not running.${NC}"
    echo "  Start it and install Docker deps:"
    echo "    docker compose --profile dev up -d"
    echo "    docker exec $DOCKER_CONTAINER npm install"
  fi

  echo ""

  # --- Host path (SMI-5343) --------------------------------------------------
  # The host node_modules tree feeds host tooling (tsc, eslint) and is symlinked
  # into every worktree — it must stay in sync with package-lock.json too.
  # Always attempt the install; advisory-only if npm is unavailable (unlikely on
  # a dev machine but graceful).
  if command -v npm > /dev/null 2>&1; then
    echo "${YELLOW}Installing updated dependencies on the host...${NC}"
    if npm install; then
      echo "${GREEN}  Host dependencies updated successfully.${NC}"
    else
      echo "${YELLOW}  Host npm install failed. Run manually:${NC}"
      echo "    npm install"
    fi
  else
    echo "${YELLOW}npm not found on host PATH — install dependencies manually:${NC}"
    echo "  npm install"
  fi

  # --- Host retrieval auto-heal (SMI-5426) -----------------------------------
  # Out-of-band: after the host install above completes, kick a detached, guarded
  # auto-heal of the host better-sqlite3 binding so ~6-week-dead retrieval
  # telemetry self-revives (SMI-4549 / SMI-5419). The script is fail-soft,
  # Docker-no-op, cheap-exits on a healthy host, serializes via a lock, backs off
  # on repeated failure, and is opt-out via SKILLSMITH_RETRIEVAL_AUTOHEAL_DISABLE=1.
  # --print-banner runs synchronously (prints only when broken); the heal runs
  # detached so it never blocks the hook. Firing AFTER the install above closes
  # the "wait for the parent install" gap. See
  # docs/internal/implementation/smi-5426-w01-host-autoheal.md.
  if command -v node > /dev/null 2>&1 && [ -f scripts/retrieval-autoheal.sh ]; then
    bash scripts/retrieval-autoheal.sh --print-banner 2>/dev/null || true
    nohup bash scripts/retrieval-autoheal.sh </dev/null >/dev/null 2>&1 &
  fi

  echo ""
fi

exit 0
