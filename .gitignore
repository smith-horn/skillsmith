# Dependencies
node_modules/
.pnpm-store/

# Ruflo AgentDB runtime persistence (hive-mind state)
agentdb.rvf
agentdb.rvf.lock

# Build outputs
dist/
*.tsbuildinfo
.turbo/
.astro/

# TypeScript build artifacts in source dirs
packages/**/*.js
packages/**/*.js.map
packages/**/*.d.ts
packages/**/*.d.ts.map
# Allow config files (not build artifacts)
!packages/**/vitest.config.ts
# Allow hand-written type declarations (not generated)
!packages/**/src/types/*.d.ts
# SMI-2742: Ambient module declaration for fts5-sql-bundle
!packages/core/src/db/drivers/fts5-sql-bundle.d.ts
!packages/**/eslint.config.js
!packages/**/astro.config.mjs
vitest.config.js
vitest.config.js.map
vitest.config.d.ts
vitest.config.d.ts.map

# Coverage
coverage/

# IDE
.idea/
.vscode/
!packages/vscode-extension/.vscode/
packages/vscode-extension/.vscode/*
!packages/vscode-extension/.vscode/launch.json
*.swp
*.swo
.DS_Store

# Environment
.env
.env.local
.env.*.local
# Explicitly allow environment templates (should be committed)
!.env.example
!.env.schema

# Logs
logs/
*.log
npm-debug.log*

# Testing
.nyc_output/

# OS
Thumbs.db

# Misc
*.bak
*.tmp

# Coordination artifacts
.claude-flow/
.swarm/
.agentic-qe/

# Confidential business documents
docs/IP/
docs/licensing/
docs/valuation/

# Sensitive configuration documentation (contains IDs, secrets)
docs/config/
*-secrets.md
*-credentials.md
stripe-config*.md
.stripe-*

# Internal planning and strategy (not public)
docs/backlog/
docs/strategy/

# Development artifacts (anchored to root level)
# SMI-4396: /data/* instead of /data/ so the SMI-4396 allowlist negation below
# can re-include its one version-controlled file — gitignore forbids negating
# a child when the parent directory itself is excluded.
/data/*
!/data/skills-security-allowlist.json
# SMI-4408: indexer blocklist for non-skill repos (imported-skill ingest filter).
!/data/indexer-blocklist.json
/output/
test-results/
playwright-report/
blob-report/

# Ignore test databases and output in packages (generated during tests)
packages/*/data/
packages/*/output/

# Phase 4 working documents (not finalized)
docs/phase4/
docs/phase4-research/
docs/architecture/phase-4.5-large-scale-testing.md
docs/architecture/phase4-trigger-system.md
docs/retros/phase-4-product-strategy.md

# Development scripts (not production)
scripts/full-import.ts
scripts/security-scan.ts
scripts/security-scan.test.ts
scripts/utils/

# Untracked scaffolding/development directories
packages/web/
/src/
docs/site/
.env.registry
.migration-checkpoint.json
.batch-transform-checkpoint.json
.batch-transform-checkpoint.json.bak
.hive-mind/
.vercel

# DNS and Email Provider Exports
*.zone
*-dns-export.txt
skillsmith.app.txt
cloudflare-*.json
resend-*.json

# Cloudflare configuration
.cloudflare/
wrangler.toml.local

# Resend webhook secrets (beyond .env)
.resend-*

# Claude Code runtime files
.claude/memory.db
.claude/hive-mind/
.claude/scheduled_tasks.lock

# Ruflo (claude-flow) runtime DB created by mcp__ruflo__swarm_init + memory_store
ruvector.db
agentdb.rvf
agentdb.rvf.lock

docs/irap/
.worktrees/

# MCP Registry tokens
.mcpregistry_*

# Blog image generation working directory
docs/articles/tmp/
