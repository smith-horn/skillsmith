# git-crypt encryption -- minimal scope
# Internal docs moved to private submodule (docs/internal/)
# Only encrypt proprietary code and business logic
# WARNING: Do NOT add a broad docs/** pattern -- docs/internal/ is a private submodule

# supabase/ -- encrypt edge functions and migrations (business logic)
supabase/functions/** filter=git-crypt diff=git-crypt
supabase/migrations/** filter=git-crypt diff=git-crypt

# supabase/ exclusion -- rollbacks must be readable during emergencies
supabase/rollbacks/** !filter !diff
